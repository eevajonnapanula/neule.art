{
  "name": "neule.art",
  "version": "1.0.0",
  "description": "Neule.art for visualising knitting patterns",
  "scripts": {
    "build": "npx @11ty/eleventy",
    "bench": "DEBUG=Eleventy:Benchmark* npx @11ty/eleventy",
    "watch": "npx @11ty/eleventy --watch",
    "serve": "npx @11ty/eleventy --serve",
    "start": "npx @11ty/eleventy --serve",
    "debug": "DEBUG=* npx @11ty/eleventy",
    "eslint": "eslint",
    "stylelint": "stylelint **/**.css",
    "lint": "npm run eslint && npm run stylelint",
    "updateStock": "node ./helpers/getColors.js"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/eevajonnapanula/neule.art"
  },
  "author": {
    "name": "Eeva-Jonna Panula",
    "email": "hello@eevis.codes",
    "url": "https://eevis.codes/"
  },
  "license": "MIT",
  "homepage": "https://neule.art",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@double-great/stylelint-a11y": "^3.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "axe-core": "^4.12.1",
    "axios": "^1.7.4",
    "cheerio": "^1.2.0",
    "cypress": "^15.18.0",
    "cypress-axe": "^1.4.0",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "firebase-admin": "^14.1.0",
    "globals": "^17.7.0",
    "node-fetch": "^2.7.0",
    "prettier": "^3.9.4",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-prettier": "^5.0.3"
  },
  "dependencies": {
    "@11ty/eleventy-upgrade-help": "^3.0.2"
  }
